{
  "consumer": {
    "name": "BazaRb"
  },
  "provider": {
    "name": "Zerocracy"
  },
  "interactions": [
    {
      "description": "an enter request without cached result",
      "providerState": "result for the \"bar\" badge for \"foo\" product not exists",
      "request": {
        "method": "get",
        "path": "/result",
        "query": "badge=bar",
        "matchingRules": {
          "$.query.badge[0]": {
            "match": "regex",
            "regex": "^[a-z0-9.]+$"
          }
        }
      },
      "response": {
        "status": 204,
        "headers": {
          "Content-Type": "text/plain"
        },
        "body": ""
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "2.0.0"
    }
  }
}