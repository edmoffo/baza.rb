{
  "consumer": {
    "name": "BazaRb"
  },
  "provider": {
    "name": "Zerocracy"
  },
  "interactions": [
    {
      "description": "a recent job check",
      "providerState": "job #42 exists",
      "request": {
        "method": "get",
        "path": "/recent/foo.txt",
        "matchingRules": {
          "$.path": {
            "match": "regex",
            "regex": "\\/recent\\/[a-z0-9]+\\.txt"
          }
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "text/plain"
        },
        "body": "42",
        "matchingRules": {
          "$.body": {
            "match": "regex",
            "regex": "^[1-9][0-9]*$"
          }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "2.0.0"
    }
  }
}