{
  "consumer": {
    "name": "BazaRb"
  },
  "provider": {
    "name": "Zerocracy"
  },
  "interactions": [
    {
      "description": "a request for CSRF token",
      "request": {
        "method": "get",
        "path": "/csrf"
      },
      "response": {
        "status": 200,
        "headers": {
        },
        "body": "csrf-token-example",
        "matchingRules": {
          "$.body": {
            "match": "regex",
            "regex": "^.+$"
          }
        }
      }
    },
    {
      "description": "a lock request",
      "providerState": "product \"foo\" exists",
      "request": {
        "method": "post",
        "path": "/lock/foo",
        "headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "body": "_csrf=csrf-token-example&owner=the-owner",
        "matchingRules": {
          "$.path": {
            "match": "regex",
            "regex": "^\\/lock\\/[a-z0-9]+$"
          },
          "$.body._csrf": {
            "match": "regex",
            "regex": "^.+$"
          },
          "$.body.owner": {
            "match": "regex",
            "regex": "^.+$"
          }
        }
      },
      "response": {
        "status": 302,
        "headers": {
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "2.0.0"
    }
  }
}