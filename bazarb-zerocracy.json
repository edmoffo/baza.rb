{
  "consumer": {
    "name": "BazaRb"
  },
  "provider": {
    "name": "Zerocracy"
  },
  "interactions": [
    {
      "description": "a request for CSRF token",
      "request": {
        "method": "get",
        "path": "/csrf"
      },
      "response": {
        "status": 200,
        "headers": {
        },
        "body": "csrf-token-example",
        "matchingRules": {
          "$.body": {
            "match": "regex",
            "regex": "^.+$"
          }
        }
      }
    },
    {
      "description": "a fee payment request",
      "providerState": "user is logged in",
      "request": {
        "method": "post",
        "path": "/account/fee",
        "headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "body": "_csrf=csrf-token-example&amount=42.77&job=42&summary=the+summary&tab=unknown",
        "matchingRules": {
          "$.body._csrf": {
            "match": "regex",
            "regex": "^.+$"
          },
          "$.body.amount": {
            "match": "regex",
            "regex": "^[0-9]+\\.[0-9]+$"
          },
          "$.body.job": {
            "match": "regex",
            "regex": "^[0-9]+$"
          },
          "$.body.summary": {
            "match": "regex",
            "regex": "^.+$"
          },
          "$.body.tab": {
            "match": "regex",
            "regex": "^[a-z]+$"
          }
        }
      },
      "response": {
        "status": 302,
        "headers": {
          "X-Zerocracy-ReceiptId": "42"
        },
        "matchingRules": {
          "$.headers.X-Zerocracy-ReceiptId": {
            "match": "regex",
            "regex": "^[1-9][0-9]*$"
          }
        }
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "2.0.0"
    }
  }
}