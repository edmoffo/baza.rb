{
  "consumer": {
    "name": "BazaRb"
  },
  "provider": {
    "name": "Zerocracy"
  },
  "interactions": [
    {
      "description": "a stdout request",
      "providerState": "job #42 exists",
      "request": {
        "method": "get",
        "path": "/stdout/42.txt",
        "matchingRules": {
          "$.path": {
            "match": "regex",
            "regex": "^\\/stdout\\/[1-9][0-9]*\\.txt$"
          }
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "text/plain"
        },
        "body": "hello, друг!"
      }
    }
  ],
  "metadata": {
    "pactSpecification": {
      "version": "2.0.0"
    }
  }
}